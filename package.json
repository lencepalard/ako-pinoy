{
  "name": "ako-pinoy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:push": "pnpm --filter @ako-pinoy/db push",
    "db:migrate": "pnpm --filter @ako-pinoy/db migrate",
    "db:studio": "pnpm --filter @ako-pinoy/db studio",
    "db:seed": "pnpm --filter @ako-pinoy/db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
