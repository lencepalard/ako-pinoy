{
  "expo": {
    "name": "Ako Pinoy",
    "slug": "ako-pinoy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ako-pinoy",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0038a8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akopinoy.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0038a8"
      },
      "package": "com.akopinoy.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-av",
        { "microphonePermission": "Allow Ako Pinoy to access your microphone for pronunciation practice." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
